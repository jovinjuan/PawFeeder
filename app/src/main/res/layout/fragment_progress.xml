<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:descendantFocusability="beforeDescendants"
    tools:context=".ProgressFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="45dp"
        android:paddingBottom="15dp"
        android:paddingLeft="15dp"
        android:paddingRight="15dp">

        <TextView
            android:id="@+id/txvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Progress"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="12dp"
            android:textColor="#1F2A44" />

        <androidx.cardview.widget.CardView
            android:id="@+id/outerStatsBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="12dp"
            android:useCompatPadding="true"
            android:backgroundTint="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="10dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardDays"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="100dp"
                                android:layout_weight="1"
                                android:gravity="center_vertical"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvDaysNumber"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="30"
                                    android:textColor="@color/black"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvDaysLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Days"
                                    android:textColor="@color/black"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvDaysNote"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Current Streak"
                                    android:textColor="#FF3B30"
                                    android:textSize="10sp"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/ivDaysIcon"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:src="@drawable/ic_fire"
                                android:scaleType="fitCenter"
                                android:contentDescription="iconDays"
                                android:padding="6dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardDrink"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="90dp"
                                android:layout_weight="1"
                                android:gravity="center_vertical"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvDrinkNumber"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="150"
                                    android:textColor="@color/black"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvDrinkLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Drink"
                                    android:textColor="@color/black"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvDrinkNote"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Drink"
                                    android:textColor="#2AA1FF"
                                    android:textSize="12sp"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/ivDrinkIcon"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_drink"
                                android:contentDescription="iconDrink"
                                android:padding="6dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardFeed"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="100dp"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tvFeedNumber"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="90"
                                    android:textSize="26sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"/>

                                <TextView
                                    android:id="@+id/tvFeedLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Feed"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"/>

                                <TextView
                                    android:id="@+id/tvFeedNote"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Feed"
                                    android:textColor="#FFB740"
                                    android:textSize="12sp"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/ivFeedIcon"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:src="@drawable/ic_feed"
                                android:contentDescription="iconFeed"
                                android:padding="6dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardRefill"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@android:color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="90dp"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tvRefillNumber"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="24"
                                    android:textSize="26sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"/>

                                <TextView
                                    android:id="@+id/tvRefillLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Refill"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"/>

                                <TextView
                                    android:id="@+id/tvRefillNote"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Refill"
                                    android:textColor="#66BB6A"
                                    android:textSize="12sp"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/ivRefillIcon"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:src="@drawable/ic_refill"
                                android:contentDescription="iconRefill"
                                android:padding="6dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardConsumption"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvConsumptionTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily Consumption"
                            android:textStyle="bold"
                            android:textColor="#1F2A44"/>

                        <TextView
                            android:id="@+id/tvConsumptionType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Water"
                            android:textSize="12sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvConsumptionSelector"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Water ▾"
                        android:textSize="12sp"
                        android:textColor="#6B7280"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/barChartContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:weightSum="7"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp">
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Badges and Achievements"
            android:textStyle="bold"
            android:textColor="#1F2A44"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <GridLayout
            android:id="@+id/gridBadges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:alignmentMode="alignMargins"
            android:rowOrderPreserved="false"
            android:layout_marginBottom="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="115dp"
                android:layout_height="115dp"
                android:layout_margin="6dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                app:layout_columnWeight="1">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="bottom"
                        android:paddingBottom="10dp"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp">

                        <TextView
                            android:id="@+id/badge1_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Automation Master"
                            android:textColor="#222222"
                            android:textSize="11sp"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/badge1_sub"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="20 feeds automated"
                            android:textColor="#9AA3B2"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="115dp"
                android:layout_height="115dp"
                android:layout_margin="6dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                app:layout_columnWeight="1">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="bottom"
                        android:paddingBottom="10dp"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp">

                        <TextView
                            android:id="@+id/badge2_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Refill Ninja"
                            android:textColor="#222222"
                            android:textSize="11sp"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/badge2_sub"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="7 refill after alert"
                            android:textColor="#9AA3B2"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="115dp"
                android:layout_height="115dp"
                android:layout_margin="6dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                app:layout_columnWeight="1">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="bottom"
                        android:paddingBottom="10dp"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp">

                        <TextView
                            android:id="@+id/badge3_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Supply Steady"
                            android:textColor="#222222"
                            android:textSize="11sp"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/badge3_sub"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="7 days no stockout"
                            android:textColor="#9AA3B2"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="115dp"
                android:layout_height="115dp"
                android:layout_margin="6dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                app:layout_columnWeight="1">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="bottom"
                        android:paddingBottom="10dp"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp">

                        <TextView
                            android:id="@+id/badge4_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Full Tank"
                            android:textColor="#222222"
                            android:textSize="11sp"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/badge4_sub"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Average Stock ≥ 50%"
                            android:textColor="#9AA3B2"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="115dp"
                android:layout_height="115dp"
                android:layout_margin="6dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                app:layout_columnWeight="1">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="bottom"
                        android:paddingBottom="10dp"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp">

                        <TextView
                            android:id="@+id/badge5_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="First Bite"
                            android:textColor="#222222"
                            android:textSize="11sp"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/badge5_sub"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1 successful feed"
                            android:textColor="#9AA3B2"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="115dp"
                android:layout_height="115dp"
                android:layout_margin="6dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                app:layout_columnWeight="1">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="bottom"
                        android:paddingBottom="10dp"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp">

                        <TextView
                            android:id="@+id/badge6_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Ready, Set, Go!"
                            android:textColor="#222222"
                            android:textSize="11sp"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/badge6_sub"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Create a schedule"
                            android:textColor="#9AA3B2"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>


    </LinearLayout>
</androidx.core.widget.NestedScrollView>
